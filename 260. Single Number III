
public class Solution {
    public int[] singleNumber(int[] nums) {
         Set<Integer> set = new HashSet<>();

        for (int i = 0;i<nums.length;i++)
        {
            if(!set.add(nums[i])){
                set.remove(nums[i]);
            }
        }
       
        int[] newNums = new int[set.size()];
        int i = 0;
        for (int num : set) {
            newNums[i] = num;
            i++;
        }
        return newNums;
    }
}
