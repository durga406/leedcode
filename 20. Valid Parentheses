#include <stdbool.h>
#include <string.h>
bool isValid(char* s) {
    int len = strlen(s);
    if (len % 2 != 0) 
        return false;
    int prevlen;
    do {
        prevlen = len;
        char* p;
        if ((p = strstr(s, "()")) || (p = strstr(s, "[]")) || (p = strstr(s, "{}"))) {              
            memmove(p, p + 2, strlen(p + 2) + 1);
            len -= 2;
        }
        
    } while (len < prevlen); 
    
    return len == 0;
}
